# ── Local development (Docker) ─────────────────────────────────────────────────
POSTGRES_USER=meusclientes
POSTGRES_PASSWORD=meusclientes123
POSTGRES_DB=meusclientes
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

DATABASE_URL=postgresql://meusclientes:meusclientes123@localhost:5432/meusclientes

# ── Auth ────────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ── App ─────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3003

# ── AI (product import) ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── File uploads (Vercel Blob) ──────────────────────────────────────────────────
# Set automatically by Vercel when you add Blob storage in the dashboard.
# For local dev: copy from Vercel dashboard → Storage → your Blob store → .env.local
BLOB_READ_WRITE_TOKEN=
